# =============================================================================
# Agentic MLOps Platform — Environment Variables
# Copy to .env and fill in values
# =============================================================================

# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=agentic
POSTGRES_PASSWORD=agentic_dev
POSTGRES_DB=agentic_mlops

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Qdrant ---
QDRANT_HOST=localhost
QDRANT_PORT=6333

# --- OpenSearch ---
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=Admin@123

# --- Feast ---
FEAST_REPO_PATH=./packages/feature-store-adapter/feature_repo

# --- MCP Gateway ---
MCP_GATEWAY_HOST=localhost
MCP_GATEWAY_PORT=8100
JWT_SECRET_KEY=dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- Agent ---
AGENT_API_HOST=localhost
AGENT_API_PORT=8000
INTENT_CONFIDENCE_THRESHOLD=0.7
MAX_PLAN_STEPS=20
MAX_RETRIES_PER_STEP=3
MAX_REPLANS=2

# --- RAG ---
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
RERANKER_MODEL=BAAI/bge-reranker-base
RAG_TOP_K=10
RAG_SCORE_THRESHOLD=0.5

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-xxx
LANGFUSE_SECRET_KEY=sk-lf-xxx

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
